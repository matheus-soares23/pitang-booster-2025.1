  "description": "repositório para metas estabelecidas no pitang booster",
  "main": "index.js",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "commit": "cz",
    "prepare": "husky",
    "release": "standard-version",
    "release:minor": "standard-version --release-as minor",
    "release:major": "standard-version --release-as major",
    "release:patch": "standard-version --release-as patch",
    "release:first": "standard-version --first-release"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/matheus-soares23/PitangBooster-2025.1.git"
  },
  "author": "Matheus Soares",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/matheus-soares23/PitangBooster-2025.1/issues"
  },
  "homepage": "https://github.com/matheus-soares23/PitangBooster-2025.1#readme",
  "dependencies": {
    "@nestjs/bull": "^11.0.3",
    "@nestjs/common": "^11.1.6",
    "@nestjs/platform-express": "^11.1.6",
    "@types/bull": "^4.10.4",
    "bull": "^4.16.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "install": "^0.13.0",
    "redis": "^5.8.2",
    "typescript": "^5.9.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@nestjs/cli": "^11.0.10",
    "@types/express": "^5.0.3",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "husky": "^9.1.7",
    "standard-version": "^9.5.0"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  }
