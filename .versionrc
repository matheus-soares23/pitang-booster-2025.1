{
  "types": [
    {"type": "feat", "section": "Features"},
    {"type": "fix", "section": "Bug Fixes"},
    {"type": "chore", "hidden": true},
    {"type": "docs", "section": "Documentation"},
    {"type": "style", "hidden": true},
    {"type": "refactor", "section": "Code Refactoring"},
    {"type": "perf", "section": "Performance Improvements"},
    {"type": "test", "hidden": true}
  ],
  "commitUrlFormat": "https://github.com/matheus-soares23/pitang-booster/commit/{{hash}}",
  "compareUrlFormat": "https://github.com/matheus-soares23/pitang-booster/compare/{{previousTag}}...{{currentTag}}",
  "issueUrlFormat": "https://github.com/matheus-soares23/pitang-booster/issues/{{id}}",
  "userUrlFormat": "https://github.com/{{user}}",
  "releaseCommitMessageFormat": "chore(release): {{currentTag}}",
  "skip": {
    "changelog": false,
    "commit": false,
    "tag": false
  }
}